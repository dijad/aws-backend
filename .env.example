# =============================================================================
# Global Notes — Backend
# Copia: cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Base de datos
# -----------------------------------------------------------------------------
# local     → Docker: docker compose up -d postgres
# cloud-sql → GCP: docs/gcp-cloud-sql.md | ./scripts/gcp/connect-local.sh
DB_TARGET=local

# --- DB_TARGET=local ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aws?schema=public

# --- DB_TARGET=cloud-sql (completa estos valores) ---
GCP_PROJECT_ID=
GCP_REGION=
CLOUD_SQL_INSTANCE=
DB_USER=
DB_PASSWORD=
DB_NAME=aws

# -----------------------------------------------------------------------------
# Servidor
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3000
AUTH_DISABLED=false

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_TTL=900
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_TTL=604800

# -----------------------------------------------------------------------------
# Usuario admin (seed)
# -----------------------------------------------------------------------------
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin123!
SEED_ADMIN_NAME=Administrator

# -----------------------------------------------------------------------------
# Email (Resend) — one email per in-app notification
# -----------------------------------------------------------------------------
EMAIL_ENABLED=true
RESEND_API_KEY=re_xxxxxxxx
# Verified sender in Resend (domain or onboarding@resend.dev for tests)
EMAIL_FROM=AWS <onboarding@resend.dev>
FRONTEND_URL=http://localhost:3000
